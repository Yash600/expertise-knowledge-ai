# ── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Vector Database (Qdrant Cloud) ────────────────────────────────────────────
QDRANT_URL=https://your-cluster-url.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=enterprise_docs

# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
# Used for: LangGraph memory checkpointer + feedback storage
SUPABASE_DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
# Clerk JWT public key (for FastAPI middleware verification)
CLERK_JWT_PUBLIC_KEY=your_clerk_jwt_public_key

# ── Frontend ──────────────────────────────────────────────────────────────────
# Set this in Vercel env vars pointing to your Render backend URL
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# ── App Config ────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app

# ── Embedding Model (runs locally, no key needed) ─────────────────────────────
# BAAI/bge-small-en-v1.5 — downloaded automatically on first run
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# ── Reranker Model (runs locally, no key needed) ──────────────────────────────
# cross-encoder/ms-marco-MiniLM-L-6-v2 — downloaded automatically on first run
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── RAG Config ────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=10              # candidates from BM25 + semantic each
RERANKER_TOP_N=3                # final chunks sent to LLM
MEMORY_WINDOW=6                 # last N messages kept in conversation memory
MULTI_DOC_THRESHOLD=3           # min unique docs to trigger map-reduce reasoning
